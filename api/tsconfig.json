{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "lib": [
      "esnext"
    ]
  },
  "include": [
    "src/**/*.js"
  ]
}